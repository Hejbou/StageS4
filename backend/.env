FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=chatia-secret-mauritanie-2024-change-me-in-prod

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=chatBot_db

JWT_SECRET_KEY=chatia-jwt-secret-mauritanie-2024-change-me-in-prod
JWT_ACCESS_TOKEN_EXPIRES_HOURS=24
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# CORS : séparés par virgule — "null" = file://
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://localhost:5500,http://127.0.0.1:5500,null

APP_PORT=5000

# Admin par défaut (créé par init_db.py)
ADMIN_PHONE=20000000
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrateur ChatIA

# Pricing
PRICING_BASE_FARE=100
PRICING_PER_BLOCK=50
PRICING_BLOCK_KM=4

# Google Maps (optionnel — fallback zones Nouakchott si vide)
